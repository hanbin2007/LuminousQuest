# Copy to .env beside the content directory or packaged executable.

# Runtime and content
LQ_PORT=4173
LQ_CONTENT_DIR=
LQ_NO_OPEN=0
LQ_LOCK_DEMO=0
LQ_TEST_NAV=0

# LLM channel. Supported providers:
# modelverse | claude-agent | deepseek | tongyi | zhipu | mock
# claude-agent uses the local Claude Code OAuth session and needs no API key.
# mock must be selected explicitly and is intended only for development/demo use.
LQ_LLM_PROVIDER=modelverse
LQ_LLM_MODEL=glm-5.2
LQ_LLM_EXECUTION_MODE=live
LLM_TIMEOUT_MS=20000

# Provider credentials. Keep unused values empty.
MODELVERSE_API_KEY=
DEEPSEEK_API_KEY=
TONGYI_API_KEY=
ZHIPU_API_KEY=

# Optional OpenAI-compatible endpoint overrides.
MODELVERSE_BASE_URL=https://api.modelverse.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Packaging only: path to an audited SEA-capable Node executable.
LQ_SEA_NODE=
