      "rubricIds": ["rubric-p3", "rubric-p4", "rubric-p5", "rubric-p6", "rubric-p7"],
      "targetNodeIds": ["P3", "P4", "P5", "P6", "P7"],
      "evidencePath": "简答原文 -> 电极产物、电子/离子过程、现象、两条电极反应式与总反应",
      "answerGuidance": [
        "负极：Zn - 2e⁻ = Zn²⁺；正极：Cu²⁺ + 2e⁻ = Cu。",
        "电子由 Zn 极经外电路流向 Cu 极，不经过盐桥。",
        "盐桥中阴离子移向负极侧，阳离子移向正极侧。",
        "锌片逐渐溶解，铜片上有铜析出、质量增加。",
        "合并两式得到 Zn + Cu^2+ = Zn^2+ + Cu，总反应中不保留电子。"
      ],
      "referenceEquations": [
        { "caseId": "zinc-copper", "equationSetId": "zinc-negative", "equation": "Zn - 2e⁻ = Zn²⁺" },
        { "caseId": "zinc-copper", "equationSetId": "copper-positive", "equation": "Cu²⁺ + 2e⁻ = Cu" },
        { "caseId": "zinc-copper", "equationSetId": "zinc-copper-overall", "equation": "Zn + Cu²⁺ = Zn²⁺ + Cu" }
      ]
    },
