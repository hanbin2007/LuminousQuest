  "questions": [
    {
      "id": "pretest-principle-reactants",
      "type": "choice",
      "prompt": "关于锌铜原电池，下列说法哪一项同时正确区分了反应场所与反应物？",
      "dimensionId": "principle",
      "rubricIds": ["rubric-p2", "rubric-d5"],
      "targetNodeIds": ["P2", "D5"],
      "evidencePath": "选择项 -> 氧化还原前提、两极反应物与场所/反应物区分",
      "options": [
        {
          "id": "A",
          "text": "Zn 是负极场所并作为还原剂失电子；Cu 是正极场所，真正得电子的反应物是 Cu²⁺。",
          "correct": true,
          "misconceptionIds": []
        },
        {
          "id": "B",
          "text": "Cu 片在正极得到电子，所以 Cu 片本身是氧化剂。",
          "correct": false,
          "misconceptionIds": ["D4-M1", "D5-M1", "P2-M2"]
        },
        {
          "id": "C",
          "text": "只要有两根不同金属和导线，任何反应都能持续发电。",
          "correct": false,
          "misconceptionIds": ["P1-M1", "D3-M4"]
        },
        {
          "id": "D",
          "text": "电子由 Cu²⁺ 经盐桥移动到 Zn。",
          "correct": false,
          "misconceptionIds": ["D3-M1", "P4-M1", "P4-M2"]
        }
      ]
    },
    {
      "id": "pretest-principle-process",
      "type": "text",
      "prompt": "写出锌铜原电池的两个电极反应式，并说明电子、盐桥中阴阳离子的方向以及可观察到的电极现象。",
      "dimensionId": "principle",
      "rubricIds": ["rubric-p3", "rubric-p4", "rubric-p5", "rubric-p6", "rubric-p7"],
      "targetNodeIds": ["P3", "P4", "P5", "P6", "P7"],
      "evidencePath": "简答原文 -> 电极产物、电子/离子过程、现象、两条电极反应式与总反应",
      "answerGuidance": [
        "负极：Zn - 2e⁻ = Zn²⁺；正极：Cu²⁺ + 2e⁻ = Cu。",
        "电子由 Zn 极经外电路流向 Cu 极，不经过盐桥。",
        "盐桥中阴离子移向负极侧，阳离子移向正极侧。",
        "锌片逐渐溶解，铜片上有铜析出、质量增加。",
        "合并两式得到 Zn + Cu^2+ = Zn^2+ + Cu，总反应中不保留电子。"
      ],
      "referenceEquations": [
        { "caseId": "zinc-copper", "equationSetId": "zinc-negative", "equation": "Zn - 2e⁻ = Zn²⁺" },
        { "caseId": "zinc-copper", "equationSetId": "copper-positive", "equation": "Cu²⁺ + 2e⁻ = Cu" },
        { "caseId": "zinc-copper", "equationSetId": "zinc-copper-overall", "equation": "Zn + Cu²⁺ = Zn²⁺ + Cu" }
      ]
    },
    {
