      ],
      "rules": [
        { "id": "d4-hit", "outcome": "hit", "score": 2, "description": "完整建立得电子场所、还原反应与惰性电极或不参与反应的普通导体之间的对应。" },
        { "id": "d4-partial", "outcome": "partial", "score": 1, "description": "能指出正极或还原反应，但场所与反应物区分不完整。" },
