      ],
      "rules": [
        { "id": "d3-hit", "outcome": "hit", "score": 2, "description": "正确说明离子导体、内电路和闭合回路。" },
        { "id": "d3-partial", "outcome": "partial", "score": 1, "description": "知道需要电解质通路，但未说明离子迁移或闭合功能。" },
        { "id": "d3-miss", "outcome": "miss", "score": 0, "description": "缺失离子通路、选择非电解质或认为盐桥传电子。" }
