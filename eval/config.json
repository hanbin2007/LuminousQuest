    "outputUsdPerMillionTokens": null
  },
  "coverage": {
    "minimumCases": 40,
    "minimumCasesPerNode": 2,
    "minimumCasesPerMisconception": 1
  },
  "live": {
    "provider": "deepseek",
    "model": "deepseek-chat"
  }
}
