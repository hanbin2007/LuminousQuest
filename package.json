{
  "name": "luminous-quest",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm run build:client && pnpm run typecheck",
    "build:client": "vite build",
    "start": "pnpm run build && tsx server/index.ts",
    "serve": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package:app": "pnpm run build && node scripts/package.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "ajv": "^8.17.1",
    "dotenv": "^17.2.3",
    "hono": "^4.11.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.27.2",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.16"
  }
}
